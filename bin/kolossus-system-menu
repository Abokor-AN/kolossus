#!/bin/bash

choice=$(printf '%s\n' "Lock" "Suspend" "Log out" "Reboot" "Shut down" | fuzzel --dmenu --prompt="System > ")

case $choice in
"Lock")
  kolossus-lock
  ;;
"Suspend")
  systemctl suspend
  ;;
"Log out")
  niri msg action quit --skip-confirmation
  ;;
"Reboot")
  systemctl reboot
  ;;
"Shut down")
  systemctl poweroff
  ;;
esac

