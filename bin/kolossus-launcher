#!/bin/bash

mode=${1:-apps}

case $mode in
apps)
  exec fuzzel
  ;;
clipboard)
  selection=$(cliphist list | fuzzel --dmenu --prompt="Clipboard > ")
  if [[ -n $selection ]]; then
    cliphist decode <<<"$selection" | wl-copy
  fi
  ;;
symbols)
  exec rofimoji --selector fuzzel
  ;;
*)
  printf 'Usage: %s [apps|clipboard|symbols]\n' "${0##*/}" >&2
  exit 2
  ;;
esac
