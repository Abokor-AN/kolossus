#!/bin/bash

set -uo pipefail

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/kolossus/session"
mkdir -p "$state_dir"
exec >>"$state_dir/startup.log" 2>&1

export PATH="$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/bin:/bin"

printf '\n[%s] Démarrage des composants Niri\n' "$(date --iso-8601=seconds)"

start_once() {
  local process_name=$1
  local log_name=$2
  shift 2

  if pgrep -x "$process_name" >/dev/null 2>&1; then
    printf 'déjà actif : %s\n' "$process_name"
    return
  fi

  printf 'démarrage : %s\n' "$process_name"
  "$@" >>"$state_dir/$log_name.log" 2>&1 &
}

start_once swaybg swaybg /usr/bin/swaybg -i "$HOME/.config/swaybg/retro-82.jpg" -m fill
start_once mako mako /usr/bin/mako
start_once waybar waybar /usr/bin/waybar --config "$HOME/.config/waybar/config.jsonc" --style "$HOME/.config/waybar/style.css"
start_once swayosd-server swayosd /usr/bin/swayosd-server
start_once swayidle swayidle "$HOME/.local/bin/kolossus-idle"

/usr/bin/wl-paste --type text --watch /usr/bin/cliphist store >>"$state_dir/clipboard-text.log" 2>&1 &
/usr/bin/wl-paste --type image --watch /usr/bin/cliphist store >>"$state_dir/clipboard-image.log" 2>&1 &
/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1 >>"$state_dir/polkit.log" 2>&1 &
"$HOME/.local/bin/kolossus-verify-session" >>"$state_dir/verification.log" 2>&1 &

sleep 4

if ! pgrep -x waybar >/dev/null 2>&1; then
  printf 'échec : Waybar ne tourne pas\n'
  /usr/bin/notify-send -u critical "Kolossus" "Waybar n’a pas démarré. Consulte ~/.local/state/kolossus/session/waybar.log" || true
  /usr/bin/alacritty -e /usr/bin/bash -lc "printf 'Waybar n’a pas démarré. Journal :\n\n'; tail -n 100 '$state_dir/waybar.log'; exec /usr/bin/bash" &
fi
