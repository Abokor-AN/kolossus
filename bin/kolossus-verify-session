#!/bin/bash

script_path=$(readlink -f "${BASH_SOURCE[0]}")
kolossus_dir=$(cd -- "$(dirname -- "$script_path")/.." && pwd)
verification_dir="$kolossus_dir/verification"
pending_file="$verification_dir/pending"

[[ -f $pending_file ]] || exit 0

sleep 8
mkdir -p "$verification_dir"

hyprctl configerrors >"$verification_dir/configerrors.txt" 2>&1 || true
hyprctl monitors -j >"$verification_dir/monitors.json" 2>&1 || true

focused_monitor=$(hyprctl monitors -j 2>/dev/null | jq -r '.[] | select(.focused) | .name' | head -n 1)
if [[ -n $focused_monitor ]] && grim -o "$focused_monitor" "$verification_dir/latest.png"; then
  capture_status=ok
else
  capture_status=failed
fi

{
  printf 'capture=%s\n' "$capture_status"
  printf 'hyprland=%s\n' "$(pgrep -x Hyprland >/dev/null && printf running || printf missing)"
  printf 'waybar=%s\n' "$(pgrep -x waybar >/dev/null && printf running || printf missing)"
  printf 'mako=%s\n' "$(pgrep -x mako >/dev/null && printf running || printf missing)"
} >"$verification_dir/status.txt"

date --iso-8601=seconds >"$verification_dir/done"
rm "$pending_file"
notify-send "Kolossus" "Vérification initiale terminée"

