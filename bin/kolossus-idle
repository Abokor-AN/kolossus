#!/bin/bash

set -euo pipefail

exec swayidle -w \
  timeout 300 'kolossus-lock' \
  timeout 310 'niri msg action power-off-monitors' \
  resume 'niri msg action power-on-monitors' \
  before-sleep 'kolossus-lock' \
  after-resume 'niri msg action power-on-monitors' \
  lock 'kolossus-lock' \
  unlock 'niri msg action power-on-monitors'
