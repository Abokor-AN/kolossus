#!/bin/bash

set -euo pipefail

if pgrep -x swaylock >/dev/null; then
  exit 0
fi

(
  sleep 3
  if pgrep -x swaylock >/dev/null; then
    niri msg action power-off-monitors >/dev/null 2>&1 || true
  fi
) &

exec swaylock \
  --daemonize \
  --color 05182e \
  --image "$HOME/.config/swaybg/retro-82.jpg" \
  --scaling fill \
  --font "JetBrainsMono Nerd Font" \
  --indicator-radius 100 \
  --indicator-thickness 4 \
  --inside-color 05182ecc \
  --ring-color f6dcacff \
  --key-hl-color faa968ff \
  --text-color f6dcacff
